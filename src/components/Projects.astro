---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

import tiksnapImg from "../assets/projects/tiksnap.webp";
import tonyranchImg from "../assets/projects/tonyranch.webp";
import skymodsImg from "../assets/projects/skymods.webp";
import bocatiImg from "../assets/projects/bocati.webp";
import melissaImg from "../assets/projects/melissahairstyle.webp";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    n: "001",
    name: t("project.tiksnap.name"),
    description: t("project.tiksnap.description"),
    tags: t("project.tiksnap.tags").split(","),
    url: "https://tiksnap.es/",
    image: tiksnapImg,
    color: "#dde8ff",
    accent: "#2563eb",
  },
  {
    n: "002",
    name: t("project.melissa.name"),
    description: t("project.melissa.description"),
    tags: t("project.melissa.tags").split(","),
    url: "https://melissahairstyle.com/",
    image: melissaImg,
    color: "#fdf4ff",
    accent: "#a855f7",
  },
  {
    n: "003",
    name: t("project.tonyranch.name"),
    description: t("project.tonyranch.description"),
    tags: t("project.tonyranch.tags").split(","),
    url: "",
    private: true,
    image: tonyranchImg,
    color: "#e0f2fe",
    accent: "#0284c7",
  },
  {
    n: "004",
    name: t("project.skymods.name"),
    description: t("project.skymods.description"),
    tags: t("project.skymods.tags").split(","),
    url: "https://skymods.vercel.app/es",
    image: skymodsImg,
    color: "#eff6ff",
    accent: "#3b82f6",
  },
  {
    n: "005",
    name: t("project.bocati.name"),
    description: t("project.bocati.description"),
    tags: t("project.bocati.tags").split(","),
    url: "https://bocati.vercel.app/",
    image: bocatiImg,
    color: "#f0fdf4",
    accent: "#16a34a",
  },
];
---

<section class="sec projects-sec" id="projects">
  <div class="section-decor">
    <div class="glass-code p-1 animate-on-scroll">
      <span class="kw">git commit</span> -m <span class="st">"feat: ship it"</span>
    </div>
    <div class="glass-code p-2 animate-on-scroll">
      <span class="vn">v1.2.0</span> - stable
    </div>
    <div class="glass-code p-3 animate-on-scroll">
      <span class="kw">merge</span> branch <span class="st">'main'</span>
    </div>
    <div class="glass-code p-4 animate-on-scroll">
      <span class="kw">git merge</span> --no-ff
    </div>
    <div class="glass-code p-5 animate-on-scroll">
      <span class="kw">DEPLOY:</span> <span class="vn">SUCCESS</span>
    </div>
    <div class="glass-code p-6 animate-on-scroll">
      <span class="vn">browsers</span> => [<span class="st">'Chrome'</span>, <span class="st">'Safari'</span>]
    </div>
    <div class="glass-code p-7 animate-on-scroll">
      <span class="vn">lighthouse</span>.score = <span class="st">100</span>
    </div>
    <div class="glass-code p-8 animate-on-scroll">
      <span class="kw">await</span> <span class="fn">deploy</span>()
    </div>
  </div>

  <div class="container">
    <h2 class="sec-title">{t("projects.title")}</h2>
    <p class="sec-sub">{t("projects.sub")}</p>

    <div class="proj-grid">
      {
        projects.map((proj) =>
          proj.url ? (
            <a
              href={proj.url}
              target="_blank"
              rel="noopener noreferrer"
              class="proj animate-on-scroll"
              style={`--proj-bg:${proj.color};--proj-accent:${proj.accent}`}
            >
              <!-- Mockup area -->
              <div class="proj-visual">
                <div class="proj-mockup">
                  <div class="mock-bar">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="mock-body">
                    <img src={proj.image.src} alt={proj.name} loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
              <!-- Info -->
              <div class="proj-info">
                <span class="proj-n">{proj.n}</span>
                <h3 class="proj-name">{proj.name}</h3>
                <p class="proj-desc">{proj.description}</p>
                <div class="proj-tags">
                  {proj.tags.map(tag => (
                    <span class="ptag">{tag}</span>
                  ))}
                </div>
              </div>
              <!-- Hover overlay -->
              <div class="proj-overlay">
                <span class="proj-visit">{t("projects.visit")}</span>
              </div>
            </a>
          ) : (
            <div
              class="proj proj-noop animate-on-scroll"
              style={`--proj-bg:${proj.color};--proj-accent:${proj.accent}`}
            >
              <div class="proj-visual">
                <div class="proj-mockup">
                  <div class="mock-bar">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="mock-body">
                    <img src={proj.image.src} alt={proj.name} loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
              <div class="proj-info">
                <span class="proj-n">{proj.n}</span>
                <h3 class="proj-name">{proj.name}</h3>
                <p class="proj-desc">{proj.description}</p>
                <div class="proj-tags">
                  {proj.tags.map(tag => (
                    <span class="ptag">{tag}</span>
                  ))}
                  <span class="proj-locked">{t("projects.private")}</span>
                </div>
              </div>
            </div>
          )
        )
      }
    </div>
  </div>
</section>

<style>
  .projects-sec {
    background: var(--bg);
    padding-top: 7rem;
    position: relative;
    overflow: hidden;
  }

  /* ── GRID ── */
  .proj-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
  }

  /* Center last item if odd */
  .proj:last-child:nth-child(odd) {
    grid-column: 1 / span 2;
    justify-self: center;
    width: 100%;
    max-width: calc(50% - 0.875rem);
  }

  @media (max-width: 768px) {
    .proj:last-child:nth-child(odd) {
      max-width: none;
    }
  }

  /* ── CARD ── */
  .proj {
    background: var(--surface);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--border);
    overflow: hidden;
    text-decoration: none;
    color: var(--fg);
    display: flex;
    flex-direction: column;
    position: relative;
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.24s;
  }

  .proj:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(37,99,235,0.12);
    border-color: var(--blue-200);
  }

  /* Visual / Mockup area */
  .proj-visual {
    background: var(--proj-bg, var(--blue-50));
    padding: 2rem 2rem 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 160px;
  }

  .proj-mockup {
    background: var(--surface);
    border-radius: 8px 8px 0 0;
    border: 1.5px solid var(--border);
    border-bottom: none;
    width: 90%;
    overflow: hidden;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
  }

  .mock-bar {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .mock-bar span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border2);
    display: block;
  }

  .mock-body {
    padding: 0;
    display: block;
    line-height: 0;
  }

  .mock-body img {
    width: 100%;
    height: auto;
    object-position: top;
    display: block;
  }

  /* Info area */
  .proj-info {
    padding: 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .proj-n {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--fg-3);
    margin-bottom: 0.35rem;
  }

  .proj-name {
    font-family: var(--display);
    font-size: 1.6rem;
    letter-spacing: 0.05em;
    color: var(--fg);
    margin-bottom: 0.6rem;
    transition: color 0.2s;
  }

  .proj:hover .proj-name { color: var(--accent); }

  .proj-desc {
    font-size: 0.83rem;
    line-height: 1.7;
    color: var(--fg-3);
    margin-bottom: 1.2rem;
    flex: 1;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .ptag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--blue-50);
    border: 1px solid var(--blue-100);
    padding: 0.25rem 0.65rem;
    border-radius: 50px;
    transition: background 0.2s;
  }

  .proj:hover .ptag {
    background: var(--blue-100);
  }

  .proj-locked {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--fg-3);
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 50px;
  }

  /* Hover overlay */
  .proj-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30,58,138,0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.28s;
    border-radius: var(--radius-xl);
  }

  .proj:hover .proj-overlay {
    opacity: 1;
  }

  .proj-visit {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .proj-noop { cursor: default; }
  .proj-noop:hover {
    transform: none;
    box-shadow: none;
    border-color: var(--border);
  }

  /* ── DECOR ── */
  .p-1 { top: 8%; right: 6%; animation-delay: 2s; }
  .p-2 { bottom: 12%; left: 5%; animation-delay: 0.5s; }
  .p-3 { 
    top: 50%; 
    left: -20px; 
    transform: translateY(-50%) rotate(-90deg); 
    animation-delay: 1.2s; 
    opacity: 0.6; 
  }
  .p-4 { top: 6%; left: 12%; animation-delay: 3s; opacity: 0.6; }
  .p-5 { bottom: 8%; right: 10%; animation-delay: 1s; transform: rotate(5deg); }
  .p-6 { 
    top: 50%; 
    right: -20px; 
    transform: translateY(-50%) rotate(-90deg); 
    animation-delay: 0.8s; 
    opacity: 0.6;
  }
  .p-7 { bottom: calc(6% - 50px); left: 10%; animation-delay: 2.5s; opacity: 0.5; }
  .p-8 { top: 82%; right: 6%; animation-delay: 1.5s; }

  @media (max-width: 1024px) {
    .p-3, .p-4, .p-7 { display: none; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .proj-grid { grid-template-columns: 1fr; }
  }
</style>
