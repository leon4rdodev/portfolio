---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    n: "001",
    name: t("project.tiksnap.name"),
    description: t("project.tiksnap.description"),
    tags: t("project.tiksnap.tags").split(","),
    url: "https://tiksnap.es/",
  },
  {
    n: "002",
    name: t("project.tonyranch.name"),
    description: t("project.tonyranch.description"),
    tags: t("project.tonyranch.tags").split(","),
    url: "",
    private: true,
  },
  {
    n: "003",
    name: t("project.skymods.name"),
    description: t("project.skymods.description"),
    tags: t("project.skymods.tags").split(","),
    url: "https://skymods.vercel.app/es",
  },
  {
    n: "004",
    name: t("project.bocati.name"),
    description: t("project.bocati.description"),
    tags: t("project.bocati.tags").split(","),
    url: "https://bocati.vercel.app/",
  },
];
---

<section class="sec" id="projects">
  <p class="sec-label">{t("projects.label")}</p>
  <h2 class="sec-title">{t("projects.title")}</h2>
  <div class="proj-list">
    {
      projects.map((proj) =>
        proj.url ? (
          <a
            href={proj.url}
            target="_blank"
            rel="noopener noreferrer"
            class="proj animate-on-scroll"
          >
            <span class="proj-n">{proj.n}</span>
            <div>
              <h3 class="proj-name">{proj.name}</h3>
              <p class="proj-desc">{proj.description}</p>
            </div>
            <div class="proj-meta">
              <div class="proj-tags">
                {proj.tags.map((tag) => (
                  <span class="ptag">{tag}</span>
                ))}
              </div>
              <span class="proj-arr">↗</span>
            </div>
          </a>
        ) : (
          <div class="proj proj-noop animate-on-scroll">
            <span class="proj-n">{proj.n}</span>
            <div>
              <h3 class="proj-name">{proj.name}</h3>
              <p class="proj-desc">{proj.description}</p>
            </div>
            <div class="proj-meta">
              <div class="proj-tags">
                {proj.tags.map((tag) => (
                  <span class="ptag">{tag}</span>
                ))}
              </div>
              <span class="proj-locked">{t("projects.private")}</span>
            </div>
          </div>
        ),
      )
    }
  </div>
</section>

<style>
  .proj-list {
    display: flex;
    flex-direction: column;
  }

  .proj {
    display: grid;
    grid-template-columns: 65px 1fr auto;
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--dim);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: padding-left 0.3s ease;
  }

  .proj::before {
    content: "";
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.02);
    transition: left 0.38s ease;
    z-index: -1;
  }

  .proj:hover::before {
    left: 0;
  }
  .proj:hover {
    padding-left: 0.8rem;
  }

  .proj-n {
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--muted);
    align-self: flex-start;
    padding-top: 0.4rem;
  }

  .proj-name {
    font-family: var(--display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .proj:hover .proj-name {
    color: var(--accent);
  }

  .proj-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.78;
    max-width: 520px;
  }

  .proj-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.8rem;
    flex-shrink: 0;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    justify-content: flex-end;
  }

  .ptag {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--dim);
    padding: 0.22rem 0.5rem;
    color: var(--muted);
    transition:
      border-color 0.2s,
      color 0.2s;
    white-space: nowrap;
  }

  .proj:hover .ptag {
    border-color: #2e2e2e;
    color: rgba(240, 236, 227, 0.65);
  }

  .proj-arr {
    font-size: 1rem;
    color: var(--muted);
    transition:
      color 0.2s,
      transform 0.2s;
  }

  .proj:hover .proj-arr {
    color: var(--accent);
    transform: translate(3px, -3px);
  }

  .proj-locked {
    font-size: 0.52rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--dim);
    padding: 0.22rem 0.5rem;
  }

  .proj-noop {
    cursor: default;
  }
  .proj-noop:hover {
    padding-left: 0;
  }
  .proj-noop::before {
    display: none;
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 1024px) {
    .proj {
      grid-template-columns: 55px 1fr;
    }
    .proj-meta {
      display: none;
    }
  }

  @media (max-width: 680px) {
    .proj {
      grid-template-columns: 1fr;
      padding: 2rem 0;
      gap: 0.8rem;
    }
    .proj-n {
      display: none;
    }
    .proj-meta {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      justify-content: flex-start;
    }
    .proj-locked {
      display: none;
    }
  }
</style>
