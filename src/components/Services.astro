---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    n: "01",
    title: t("services.web.title"),
    desc: t("services.web.description"),
  },
  {
    n: "02",
    title: t("services.landing.title"),
    desc: t("services.landing.description"),
  },
  {
    n: "03",
    title: t("services.software.title"),
    desc: t("services.software.description"),
  },
  {
    n: "04",
    title: t("services.api.title"),
    desc: t("services.api.description"),
  },
];
---

<section class="sec" id="services">
  <p class="sec-label">{t("services.label")}</p>
  <h2 class="sec-title">{t("services.title")}</h2>
  <div class="svc-grid">
    {
      services.map((svc) => (
        <div class="svc animate-on-scroll">
          <p class="svc-n">{svc.n}</p>
          <h3 class="svc-name">{svc.title}</h3>
          <p class="svc-desc">{svc.desc}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--dim);
  }

  .svc {
    padding: 3rem;
    border-right: 1px solid var(--dim);
    border-bottom: 1px solid var(--dim);
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .svc:nth-child(2n) {
    border-right: none;
  }
  .svc:nth-child(3),
  .svc:nth-child(4) {
    border-bottom: none;
  }

  .svc::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    transition: width 0.4s ease;
  }

  .svc:hover::after {
    width: 100%;
  }
  .svc:hover {
    background: rgba(255, 255, 255, 0.018);
  }

  .svc-n {
    font-family: var(--display);
    font-size: 2.5rem;
    color: var(--dim);
    line-height: 1;
    margin-bottom: 1.8rem;
    transition: color 0.3s;
  }

  .svc:hover .svc-n {
    color: var(--accent);
  }

  .svc-name {
    font-family: var(--display);
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .svc-desc {
    font-size: 0.82rem;
    line-height: 1.85;
    color: var(--muted);
  }

  @media (max-width: 680px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }
    .svc {
      border-right: none;
    }
    .svc:nth-child(3) {
      border-bottom: 1px solid var(--dim);
    }
    .svc:last-child {
      border-bottom: none;
    }
  }
</style>
