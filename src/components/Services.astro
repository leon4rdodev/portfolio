---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    n: "01",
    title: t("services.web.title"),
    desc: t("services.web.description"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    n: "02",
    title: t("services.landing.title"),
    desc: t("services.landing.description"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>`,
  },
  {
    n: "03",
    title: t("services.software.title"),
    desc: t("services.software.description"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    n: "04",
    title: t("services.api.title"),
    desc: t("services.api.description"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  },
];
---

<!-- Services section -->
<section class="sec services-sec" id="services">
  <div class="section-decor">
    <div class="glass-code s-1 animate-on-scroll">
      <span class="fn">docker-compose</span> up -d
    </div>
    <div class="glass-code s-2 animate-on-scroll">
      <span class="kw">POST</span> /api/v1/ship
    </div>
    <div class="glass-code s-3 animate-on-scroll">
      <span class="kw">kubectl</span> get pods
    </div>
    <div class="glass-code s-4 animate-on-scroll">
      <span class="fn">docker build</span> -t app .
    </div>
    <div class="glass-code s-5 animate-on-scroll">
      <span class="vn">app</span>.<span class="fn">use</span>(<span class="fn">cors</span>())
    </div>
    <div class="glass-code s-6 animate-on-scroll">
      <span class="vn">server</span>.<span class="fn">listen</span>(<span class="st">3000</span>)
    </div>
    <div class="glass-code s-7 animate-on-scroll">
      <span class="kw">npm install</span> @astrojs/react
    </div>
  </div>

  <div class="container">
    <h2 class="sec-title">{t("services.title")}</h2>
    <p class="sec-sub">{t("services.sub")}</p>

    <div class="svc-grid">
      {
        services.map((svc) => (
          <div class="svc animate-on-scroll">
            <div class="svc-icon" set:html={svc.icon} />
            <h3 class="svc-name">{svc.title}</h3>
            <p class="svc-desc">{svc.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── SERVICES SECTION ── */
  .services-sec {
    background: var(--bg);
    padding: 5rem 0 8rem; /* No side padding on desktop */
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  /* ── GRID ── */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .svc {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border);
    transition:
      border-color 0.25s,
      background 0.25s,
      transform 0.25s,
      box-shadow 0.25s;
    position: relative;
    overflow: hidden;
  }

  .svc::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--blue-50) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .svc:hover::before { opacity: 1; }

  .svc:hover {
    border-color: var(--blue-200);
    background: var(--blue-50);
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(37,99,235,0.1);
  }

  /* Icon */
  .svc-icon {
    width: 52px;
    height: 52px;
    background: var(--accent-light);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    color: var(--accent);
    transition: background 0.25s, color 0.25s;
  }

  .svc-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .svc:hover .svc-icon {
    background: var(--accent);
    color: #fff;
  }

  .svc-name {
    font-family: var(--display);
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
    color: var(--fg);
    position: relative;
  }

  .svc-desc {
    font-size: 0.82rem;
    line-height: 1.75;
    color: var(--fg-3);
    position: relative;
  }

  /* ── DECOR ── */
  .s-1 { top: 6%; left: 6%; animation-delay: 0s; }
  .s-2 { bottom: 8%; right: 5%; animation-delay: 1.5s; opacity: 0.45; }
  .s-3 { top: 18%; right: 6%; animation-delay: 0.8s; transform: rotate(8deg); }
  .s-4 { top: 4%; right: 15%; animation-delay: 2.2s; opacity: 0.6; }
  .s-5 { bottom: 6%; left: 50%; animation-delay: 1.1s; transform: translateX(-50%) rotate(-5deg); }
  .s-6 { top: 28%; left: 5%; animation-delay: 3s; }
  .s-7 { bottom: 4%; left: 6%; animation-delay: 0.5s; opacity: 0.4; }

  @media (max-width: 1024px) {
    .s-3, .s-5, .s-7 { display: none; }
    .svc-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 680px) {
    .services-sec { padding: 3rem 1.5rem 8rem; } /* Restore side padding for mobile single-column layout */
    .svc-grid { grid-template-columns: 1fr; gap: 1rem; }
    .svc { padding: 1.5rem; text-align: left; }
    .svc-icon { margin: 0 0 1rem; }
  }
</style>
