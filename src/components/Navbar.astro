---
import type { Lang } from "../i18n/ui";
import {
  useTranslations,
  getAlternateUrl,
  getAlternateLang,
} from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateUrl = getAlternateUrl(Astro.url);
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
---

<nav id="nav" class={isHome ? "" : "subpage"}>
  <div class="nav-inner">
    <a href={`/${lang}/`} class="nav-logo" style="text-transform:lowercase"><span class="br">&lt;</span>leon<span class="n4">4</span>rdo<span class="br">/&gt;</span></a>

    <ul class="nav-links">
      <li><a href={`/${lang}/#about`}>{t("nav.about")}</a></li>
      <li><a href={`/${lang}/#services`}>{t("nav.services")}</a></li>
      <li><a href={`/${lang}/#projects`}>{t("nav.projects")}</a></li>
      <li><a href={`/${lang}/blog/`}>{t("nav.blog")}</a></li>
      <li><a href={`/${lang}/faq/`}>{t("nav.faq")}</a></li>
      <li><a href={`/${lang}/#contact`}>{t("nav.contact")}</a></li>
      <li>
        <a href={alternateUrl} class="nav-lang">{alternateLang.toUpperCase()}</a>
      </li>
      <li><a href={`/${lang}/#contact`} class="nav-cta">{t("nav.cta")}</a></li>
    </ul>

    <button class="hamburger" id="burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile overlay -->
<div class="mob-overlay" id="mob-overlay">
  <ul class="mob-nav">
    <li><a href={`/${lang}/#about`}>{t("nav.about")}</a></li>
    <li><a href={`/${lang}/#services`}>{t("nav.services")}</a></li>
    <li><a href={`/${lang}/#projects`}>{t("nav.projects")}</a></li>
    <li><a href={`/${lang}/blog/`}>{t("nav.blog")}</a></li>
    <li><a href={`/${lang}/faq/`}>{t("nav.faq")}</a></li>
    <li><a href={`/${lang}/#contact`} class="mob-cta">{t("nav.cta")}</a></li>
  </ul>
  <div class="mob-footer">
    <a href={alternateUrl}>{alternateLang === "es" ? "🇩🇴 ES" : "🇺🇸 EN"}</a>
    <a href="https://wa.me/18493997434" target="_blank">WhatsApp</a>
    <a href="mailto:leon4rdodev@gmail.com">Email</a>
    <a href="https://github.com/leon4rdodev" target="_blank">GitHub</a>
  </div>
</div>

<style>
  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    transition:
      background 0.3s,
      box-shadow 0.3s;
    padding: 0 2rem;
  }

  nav.scrolled {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 2px 20px rgba(37, 99, 235, 0.08);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1.3rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Logo */
  .nav-logo {
    font-family: var(--display);
    font-size: 1.05rem;
    letter-spacing: 0.28em;
    color: #ffffff;
    text-decoration: none;
    z-index: 600;
    position: relative;
    transition: color 0.25s;
  }

  nav.subpage .nav-logo,
  nav.scrolled .nav-logo, 
  nav.menu-open .nav-logo { color: var(--fg); }

  .nav-logo .n4 { color: var(--blue-400); }
  nav.subpage .nav-logo .n4,
  nav.scrolled .nav-logo .n4, 
  nav.menu-open .nav-logo .n4 { color: var(--accent); }

  .nav-logo .br { color: rgba(255,255,255,0.4); }
  nav.subpage .nav-logo .br,
  nav.scrolled .nav-logo .br, 
  nav.menu-open .nav-logo .br { color: var(--border2); }

  /* Links */
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: #fff; }

  nav.subpage .nav-links a { color: var(--fg-2); }
  nav.subpage .nav-links a:hover { color: var(--accent); }

  nav.scrolled .nav-links a { color: var(--fg-2); }
  nav.scrolled .nav-links a:hover { color: var(--accent); }

  /* Lang badge */
  .nav-lang {
    font-size: 0.65rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.14em !important;
    border: 1.5px solid rgba(255,255,255,0.3) !important;
    padding: 0.28rem 0.65rem;
    border-radius: 50px;
    transition: border-color 0.2s, color 0.2s !important;
  }

  nav.subpage .nav-lang {
    border-color: var(--border2) !important;
    color: var(--fg-2) !important;
  }

  nav.scrolled .nav-lang {
    border-color: var(--border2) !important;
    color: var(--fg-2) !important;
  }

  .nav-lang:hover {
    border-color: #fff !important;
    color: #fff !important;
  }

  nav.subpage .nav-lang:hover {
    border-color: var(--accent) !important;
    color: var(--accent) !important;
  }

  nav.scrolled .nav-lang:hover {
    border-color: var(--accent) !important;
    color: var(--accent) !important;
  }

  /* CTA button */
  .nav-cta {
    font-size: 0.78rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em !important;
    color: var(--fg) !important;
    background: #ffffff;
    padding: 0.65rem 1.7rem;
    border-radius: 50px;
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s !important;
  }

  .nav-cta:hover {
    background: var(--blue-50) !important;
    color: var(--accent) !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0,0,0,0.15) !important;
  }

  nav.subpage .nav-cta {
    background: var(--accent) !important;
    color: #fff !important;
  }

  nav.subpage .nav-cta:hover {
    background: var(--accent-h) !important;
    color: #fff !important;
    box-shadow: 0 6px 18px rgba(37,99,235,0.3) !important;
  }

  nav.scrolled .nav-cta {
    background: var(--accent) !important;
    color: #fff !important;
  }

  nav.scrolled .nav-cta:hover {
    background: var(--accent-h) !important;
    color: #fff !important;
    box-shadow: 0 6px 18px rgba(37,99,235,0.3) !important;
  }

  /* ── HAMBURGER ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px 0 4px 4px;
    z-index: 600;
    position: relative;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: rgba(255,255,255,0.85);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.2s;
    transform-origin: center;
  }

  nav.subpage .hamburger span,
  nav.scrolled .hamburger span,
  nav.menu-open .hamburger span { background: var(--fg); }

  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── MOBILE MENU ── */
  .mob-overlay {
    position: fixed;
    inset: 0;
    background: rgba(248, 250, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 400;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 2rem 3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .mob-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mob-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 280px;
    margin: 0 auto;
    width: 100%;
  }

  .mob-nav a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--fg-2);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    transition: background 0.2s, color 0.2s;
  }

  .mob-nav a:hover { 
    color: var(--accent);
    background: var(--blue-50);
  }

  .mob-nav .mob-cta {
    margin-top: 0.75rem;
    background: var(--accent);
    color: #fff;
    justify-content: center;
    border-radius: 50px;
    padding: 0.85rem;
    font-weight: 700;
  }

  .mob-nav .mob-cta:hover {
    background: var(--accent-h);
    color: #fff;
  }

  .mob-footer {
    margin-top: 2rem;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    max-width: 280px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  .mob-footer a {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--fg-3);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .mob-footer a:hover { 
    color: var(--accent);
    background: var(--blue-50);
  }




  .mob-footer a:hover { 
    color: var(--accent); 
    border-color: var(--accent);
  }

  /* ── BREAKPOINT ── */
  @media (max-width: 680px) {
    .hamburger { display: flex; }
    .nav-links { display: none; }
    .nav-inner { padding: 1.2rem 0; }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("nav");

    // Scroll effect
    const handleScroll = () => {
      navbar?.classList.toggle("scrolled", window.scrollY > 60);
    };
    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });

    // Mobile menu
    const burger = document.getElementById("burger");
    const overlay = document.getElementById("mob-overlay");

    function toggleMenu(force?: boolean) {
      const isOpen =
        force !== undefined ? force : !burger?.classList.contains("is-open");
      burger?.classList.toggle("is-open", isOpen);
      overlay?.classList.toggle("is-open", isOpen);
      navbar?.classList.toggle("menu-open", isOpen);
      document.body.style.overflow = isOpen ? "hidden" : "";
    }

    burger?.addEventListener("click", () => toggleMenu());

    overlay?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => toggleMenu(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") toggleMenu(false);
    });
  });
</script>
