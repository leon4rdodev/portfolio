---
import type { Lang } from "../i18n/ui";
import {
  useTranslations,
  getAlternateUrl,
  getAlternateLang,
} from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateUrl = getAlternateUrl(Astro.url);
---

<nav id="nav">
  <a href={`/${lang}/`} class="nav-logo">LEON<span>4</span>RDO</a>
  <ul class="nav-links">
    <li><a href="#about">{t("nav.about")}</a></li>
    <li><a href="#services">{t("nav.services")}</a></li>
    <li><a href="#projects">{t("nav.projects")}</a></li>
    <li>
      <a href={alternateUrl} class="nav-lang">{alternateLang.toUpperCase()}</a>
    </li>
    <li><a href="#contact" class="nav-cta">{t("nav.cta")}</a></li>
  </ul>
  <button class="hamburger" id="burger" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div class="mob-overlay" id="mob-overlay">
  <ul class="mob-nav">
    <li><a href="#about" class="mob-l">{t("nav.about")}</a></li>
    <li><a href="#services" class="mob-l">{t("nav.services")}</a></li>
    <li><a href="#projects" class="mob-l">{t("nav.projects")}</a></li>
    <li><a href="#contact" class="mob-l">{t("nav.contact")}</a></li>
  </ul>
  <div class="mob-footer">
    <a href={alternateUrl}>{alternateLang.toUpperCase()} →</a>
    <a href="https://wa.me/18096654820" target="_blank">WhatsApp →</a>
    <a href="mailto:leon4rdodev@gmail.com">leon4rdodev@gmail.com</a>
    <a href="https://github.com/leon4rdodev" target="_blank">GitHub →</a>
  </div>
</div>

<style>
  /* ══ NAV ══ */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.6rem 3rem;
    transition: background 0.3s;
  }

  nav.scrolled {
    background: rgba(8, 8, 8, 0.96);
    border-bottom: 1px solid var(--dim);
    backdrop-filter: blur(10px);
  }

  .nav-logo {
    font-family: var(--display);
    font-size: 1rem;
    letter-spacing: 0.3em;
    color: var(--white);
    text-decoration: none;
    z-index: 600;
    position: relative;
  }

  .nav-logo span {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .nav-links a:hover {
    opacity: 1;
  }

  .nav-lang {
    font-size: 0.62rem !important;
    letter-spacing: 0.15em;
    border: 1px solid var(--dim);
    padding: 0.35rem 0.7rem;
    opacity: 0.6 !important;
    transition:
      opacity 0.2s,
      border-color 0.2s !important;
  }

  .nav-lang:hover {
    opacity: 1 !important;
    border-color: var(--accent) !important;
    color: var(--accent) !important;
  }

  .nav-cta {
    font-size: 0.72rem !important;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black) !important;
    background: var(--accent);
    padding: 0.5rem 1.1rem;
    opacity: 1 !important;
    transition: background 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--white);
  }

  /* ══ HAMBURGER ══ */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
    z-index: 600;
    position: relative;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--white);
    transition:
      transform 0.3s ease,
      opacity 0.2s;
    transform-origin: center;
  }

  .hamburger.is-open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.is-open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.is-open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ══ MOBILE MENU ══ */
  .mob-overlay {
    position: fixed;
    inset: 0;
    background: var(--black);
    z-index: 400;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .mob-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mob-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin-top: 4rem;
  }

  .mob-nav li {
    border-bottom: 1px solid var(--dim);
  }

  .mob-nav a {
    display: block;
    font-family: var(--display);
    font-size: clamp(2.8rem, 12vw, 4.5rem);
    letter-spacing: 0.04em;
    color: var(--white);
    text-decoration: none;
    padding: 1rem 0;
    transition:
      color 0.2s,
      padding-left 0.25s;
  }

  .mob-nav a:hover {
    color: var(--accent);
    padding-left: 0.6rem;
  }

  .mob-footer {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .mob-footer a {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .mob-footer a:hover {
    color: var(--accent);
  }

  @media (max-width: 680px) {
    .hamburger {
      display: flex;
    }
    .nav-links {
      display: none;
    }
    nav {
      padding: 1.3rem 1.5rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("nav");
    window.addEventListener(
      "scroll",
      () => {
        navbar?.classList.toggle("scrolled", window.scrollY > 50);
      },
      { passive: true },
    );

    const burger = document.getElementById("burger");
    const overlay = document.getElementById("mob-overlay");

    function toggleMenu(force?: boolean) {
      const isOpen =
        force !== undefined ? force : !burger?.classList.contains("is-open");
      burger?.classList.toggle("is-open", isOpen);
      overlay?.classList.toggle("is-open", isOpen);
      document.body.style.overflow = isOpen ? "hidden" : "";
    }

    burger?.addEventListener("click", () => toggleMenu());

    overlay?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => toggleMenu(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") toggleMenu(false);
    });
  });
</script>
