---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const metaItems = [
  {
    label: t("about.meta.location.label"),
    value: t("about.meta.location.value"),
  },
  {
    label: t("about.meta.timezone.label"),
    value: t("about.meta.timezone.value"),
  },
  {
    label: t("about.meta.languages.label"),
    value: t("about.meta.languages.value"),
  },
  {
    label: t("about.meta.availability.label"),
    value: t("about.meta.availability.value"),
  },
  {
    label: t("about.meta.github.label"),
    value: t("about.meta.github.value"),
    href: "https://github.com/leon4rdodev",
  },
];
---

<section class="sec" id="about">
  <p class="sec-label">{t("about.label")}</p>
  <h2 class="sec-title">{t("about.title")}</h2>
  <div class="about-grid">
    <div class="about-body animate-on-scroll">
      <p set:html={t("about.p1")} />
      <p set:html={t("about.p2")} />
      <p set:html={t("about.p3")} />
    </div>
    <div class="about-meta animate-on-scroll">
      {
        metaItems.map((item) => (
          <div class="mi">
            <p class="mi-label">{item.label}</p>
            <p class="mi-val">
              {item.href ? (
                <a href={item.href} target="_blank" rel="noopener noreferrer">
                  {item.value}
                </a>
              ) : (
                item.value
              )}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .about-body :global(p) {
    font-size: 0.92rem;
    line-height: 1.95;
    color: rgba(240, 236, 227, 0.58);
    margin-bottom: 1.5rem;
  }

  .about-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .about-body :global(em) {
    color: var(--white);
    font-style: normal;
  }

  .about-meta {
    border-left: 1px solid var(--dim);
    padding-left: 2.5rem;
  }

  .mi {
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--dim);
  }

  .mi:last-child {
    border-bottom: none;
  }

  .mi-label {
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.45rem;
  }

  .mi-val {
    font-size: 0.85rem;
    color: var(--white);
    line-height: 1.6;
  }

  .mi-val a {
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid var(--dim);
    transition: border-color 0.2s;
  }

  .mi-val a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-meta {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--dim);
      padding-top: 2.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
    .mi {
      border-right: 1px solid var(--dim);
      padding-right: 2rem;
    }
    .mi:nth-child(2n) {
      border-right: none;
      padding-right: 0;
      padding-left: 2rem;
    }
  }
</style>
