---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import userAvatar from "../assets/icon/leon4rdo.webp";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const metaItems = [
  {
    label: t("about.meta.location.label"),
    value: t("about.meta.location.value"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    label: t("about.meta.timezone.label"),
    value: t("about.meta.timezone.value"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    label: t("about.meta.languages.label"),
    value: t("about.meta.languages.value"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    label: t("about.meta.availability.label"),
    value: t("about.meta.availability.value"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    label: t("about.meta.github.label"),
    value: t("about.meta.github.value"),
    href: "https://github.com/leon4rdodev",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
  },
];
---

<section class="about-outer" id="about">
  <div class="about-inner container">

    <!-- Left: text -->
    <div class="about-text animate-on-scroll">
      <h2 class="about-heading">{t("about.title")}</h2>
      <div class="about-body">
        <p set:html={t("about.p1")} />
        <p set:html={t("about.p2")} />
        <p set:html={t("about.p3")} />
      </div>
      <a href="#contact" class="btn-primary" style="margin-top:2rem">
        {lang === "es" ? "Trabajemos juntos →" : "Let's work together →"}
      </a>
    </div>

    <!-- Right: meta card -->
    <div class="about-card animate-on-scroll">
      <div class="about-badge">
        <div class="badge-avatar">
          <img
            src={userAvatar.src}
            alt="Leonardo Victoriano"
            width="100"
            height="100"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="badge-name">Leonardo Victoriano</p>
        <p class="badge-role">Fullstack Developer</p>
      </div>

      <ul class="meta-list">
        {
          metaItems.map((item) => (
            <li class="mi">
              <span class="mi-icon" set:html={item.icon} />
              <div>
                <p class="mi-label">{item.label}</p>
                <p class="mi-val">
                  {item.href ? (
                    <a href={item.href} target="_blank" rel="noopener noreferrer">
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                </p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

  </div>
</section>

<style>
  /* ── LIGHT ABOUT SECTION ── */
  .about-outer {
    background: var(--bg);
    padding: 7rem 2rem 14rem;
    position: relative;
    border-bottom: 1px solid var(--border);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  /* ── LEFT TEXT ── */
  .about-text .sec-label {
    color: var(--accent);
  }

  .about-heading {
    font-family: var(--display);
    font-size: clamp(2.8rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0.04em;
    color: var(--fg);
    margin-bottom: 2rem;
  }

  .about-body p {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--fg-2);
    margin-bottom: 1.25rem;
  }

  .about-body p:last-child { margin-bottom: 0; }

  .about-body :global(em) {
    color: var(--fg);
    font-style: normal;
    font-weight: 600;
  }

  /* ── RIGHT CARD ── */
  .about-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: 0 12px 40px rgba(0,0,0,0.03);
    overflow: hidden;
  }

  .about-badge {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
  }

  .badge-avatar {
    width: 100px; height: 100px;
    border: 3px solid var(--border);
    border-radius: 50%;
    margin: 0 auto 1rem;
    overflow: hidden;
    background: var(--blue-50);
    box-shadow: 0 8px 24px rgba(37,99,235,0.08);
  }

  .badge-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .badge-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 0.25rem;
  }

  .badge-role {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
  }

  /* Meta list */
  .meta-list {
    padding: 0;
    list-style: none;
    margin: 0;
  }

  .mi {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.75rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .mi:last-child { border-bottom: none; }
  .mi:hover { background: var(--blue-50); }

  .mi-icon {
    width: 36px; height: 36px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .mi:hover .mi-icon {
    background: #fff;
    border-color: var(--blue-200);
  }

  .mi-icon :global(svg) { width: 16px; height: 16px; }

  .mi-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 0.18rem;
  }

  .mi-val {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg-2);
  }

  .mi-val a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .mi-val a:hover { color: var(--blue-700); text-decoration: underline; }

  /* Responsive */
  @media (max-width: 1024px) {
    .about-inner { grid-template-columns: 1fr; gap: 3rem; }
    .about-card { max-width: 480px; margin: 0 auto; }
  }
</style>
