---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";
import userAvatar from "../assets/icon/leon4rdo.webp";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stackTags = [
  { label: "Next.js", icon: "simple-icons:nextdotjs" },
  { label: "React", icon: "simple-icons:react" },
  { label: "React Native", icon: "simple-icons:react" },
  { label: "Astro", icon: "simple-icons:astro" },
  { label: "NestJS", icon: "simple-icons:nestjs" },
  { label: "Node.js", icon: "simple-icons:nodedotjs" },
  { label: "TypeScript", icon: "simple-icons:typescript" },
  { label: "PostgreSQL", icon: "simple-icons:postgresql" },
  { label: "MongoDB", icon: "simple-icons:mongodb" },
  { label: "Docker", icon: "simple-icons:docker" },
  { label: "Supabase", icon: "simple-icons:supabase" },
];
---

<section class="hero-outer">
  <div class="section-decor" aria-hidden="true">
    <div class="glass-code h-1">
      <span class="kw">npx</span> create-next-app@latest
    </div>
    <div class="glass-code h-2">
      <span class="kw">const</span> <span class="vn">&#123;Leon4rdo&#125;</span> = <span class="fn">require</span>(<span class="st">'portfolio'</span>)
    </div>
    <div class="glass-code h-4">
      <span class="kw">import</span> &#123; <span class="vn">Ship</span> &#125; <span class="kw">from</span> <span class="st">'prod'</span>
    </div>
    <div class="glass-code h-5">
      <span class="fn">bun</span> run dev
    </div>
    <div class="glass-code h-8">
      &lt;<span class="vn">Container</span> /&gt;
    </div>
    <div class="glass-code h-tag-1">&lt;/&gt;</div>
    <div class="glass-code h-tag-2">&lt;/&gt;</div>
  </div>

  <div class="hero-inner">

    <div class="hero-content">
      <!-- Tagline — THE hero statement -->
      <h1 class="hero-tagline">{t("hero.tagline")}</h1>

      <!-- Short bio -->
      <p class="hero-bio">{t("hero.bio")}</p>

      <!-- Stack tags -->
      <div class="hero-tags">
        {stackTags.map((tag) => (
          <span class="htag">
            <Icon name={tag.icon} class="htag-icon" aria-hidden="true" />
            {tag.label}
          </span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="hero-cta">
        <a href="#contact" class="btn-primary">{t("hero.cta")}</a>
        <a href="#projects" class="btn-outline-white">{t("hero.cta2")}</a>
      </div>

      <!-- Availability note -->
      <p class="hero-avail-note">{t("hero.eyebrow")}</p>
    </div>

    <!-- Avatar -->
    <div class="hero-image">
      <div class="avatar-ring">
        <img
          src={userAvatar.src}
          alt={`Leonardo Victoriano — ${t("hero.role")}`}
          width="400"
          height="400"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>

  <!-- Wave Divider -->
  <div class="hero-wave">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path fill="currentColor" d="M0,64L80,69.3C160,75,320,85,480,80C640,75,800,53,960,48C1120,43,1280,53,1360,58.7L1440,64L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path>
    </svg>
  </div>
</section>

<style>
  /* ── BLUE HERO ── */
  .hero-outer {
    background: linear-gradient(150deg, var(--blue-700) 0%, var(--blue-600) 55%, var(--blue-500) 100%);
    padding: 10rem 2rem 14rem;
    position: relative;
    overflow: hidden;
  }

  /* ── DECOR ── */
  /* ── DECOR ── */
  .h-1 { top: 6%; left: 4%; animation-delay: 0s; }
  .h-2 { top: calc(9% + 120px); right: 6%; animation-delay: 1.2s; transform: rotate(30deg); }
  .h-4 { bottom: 22%; right: 4%; animation-delay: 2.1s; transform: rotate(-3deg); }
  .h-5 { top: 65%; left: 3%; animation-delay: 0.8s; opacity: 0.6; }
  .h-8 { bottom: 8%; left: 6%; animation-delay: 1.7s; opacity: 0.5; }

  /* ── GIANT TAGS ── */
  .h-tag-1, .h-tag-2 {
    font-size: 22rem;
    font-weight: 900;
    opacity: 0.04;
    padding: 0;
    background: none;
    backdrop-filter: none;
    border: none;
    box-shadow: none;
    color: #fff;
    pointer-events: none;
    z-index: -1;
  }
  .h-tag-1 { top: -5%; right: -2%; transform: rotate(15deg); }
  .h-tag-2 { bottom: 10%; left: -5%; transform: rotate(-20deg); }


  /* ── WAVE DIVIDER ── */
  .hero-wave {
    position: absolute;
    bottom: -1px; /* Prevents 1px gap bug in some screens */
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    pointer-events: none;
    z-index: 2;
  }

  .hero-wave svg {
    display: block;
    width: calc(100% + 1.3px);
    height: 80px;
    color: var(--bg);
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 4rem;
  }

  /* ── TEXT CONTENT ── */
  .hero-content {
    flex: 1;
    text-align: left;
  }

  /* ── AVATAR IMAGE ── */
  .hero-image {
    flex-shrink: 0;
    animation: fadeUp 0.6s 0.2s both;
  }

  /* ── TAGLINE — main heading ── */
  .hero-tagline {
    font-size: clamp(1.6rem, 3.2vw, 2.6rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #ffffff;
    max-width: 580px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.7s 0.2s both;
  }

  /* ── BIO ── */
  .hero-bio {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.75;
    color: rgba(255,255,255,0.8);
    max-width: 600px;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s 0.3s both;
  }

  /* ── STACK TAGS ── */
  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-start;
    margin-bottom: 2.5rem;
    max-width: 600px;
    animation: fadeUp 0.6s 0.4s both;
  }

  .htag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.35rem 0.8rem;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s;
  }

  .htag-icon {
    width: 1.05rem;
    height: 1.05rem;
    display: inline-block;
    flex-shrink: 0;
    color: #fff;
    opacity: 0.92;
    border: 0;
    outline: none;
    box-shadow: none;
    background: transparent;
  }

  .htag:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  /* ── CTAs ── */
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s 0.5s both;
  }

  /* White CTA on blue bg */
  .hero-cta :global(.btn-primary) {
    background: #ffffff;
    color: var(--blue-600);
  }
  .hero-cta :global(.btn-primary:hover) {
    background: var(--blue-50);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    color: var(--blue-700);
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    color: rgba(255,255,255,0.85);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    border: 2px solid rgba(255,255,255,0.3);
    text-decoration: none;
    transition: background 0.22s, border-color 0.22s, color 0.22s, transform 0.18s;
    white-space: nowrap;
  }

  .btn-outline-white:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.8);
    color: #fff;
    transform: translateY(-2px);
  }

  /* ── AVAILABILITY NOTE ── */
  .hero-avail-note {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    animation: fadeUp 0.6s 0.6s both;
  }

  .avatar-ring {
    width: clamp(280px, 30vw, 400px);
    height: clamp(280px, 30vw, 400px);
    border-radius: 50%;
    overflow: hidden;
    animation: float 6s ease-in-out infinite;
    box-shadow:
      0 0 0 6px rgba(255,255,255,0.15),
      0 0 0 14px rgba(255,255,255,0.06),
      0 30px 60px rgba(0,0,0,0.25);
    background: var(--blue-600);
  }

  .avatar-ring img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero-outer { padding: 8rem 1.5rem 12rem; }
    .hero-inner {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }
    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .hero-tags { justify-content: center; }
    .hero-cta { justify-content: center; }
    .hero-image { order: -1; }
    .avatar-ring {
      width: 240px;
      height: 240px;
    }
  }

  @media (max-width: 600px) {
    .hero-tagline { font-size: clamp(2rem, 8vw, 2.8rem); line-height: 1.1; }
    .hero-cta { flex-direction: column; width: 100%; }
    .hero-cta > a { width: 100%; justify-content: center; }
  }

  /* ── RESPONSIVE SECTION DECOR ── */
  @media (max-width: 1024px) {
    .h-7, .h-8, .h-9 { display: none; }
  }

</style>
