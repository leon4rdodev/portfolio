---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  {
    name: t("contact.whatsapp"),
    sub: t("contact.whatsapp.sub"),
    href: "https://wa.me/18493997434",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    color: "#22c55e",
    colorBg: "#f0fdf4",
  },
  {
    name: t("contact.email"),
    sub: t("contact.email.sub"),
    href: "mailto:leon4rdodev@gmail.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    color: "#2563eb",
    colorBg: "#eff5ff",
  },
  {
    name: t("contact.github"),
    sub: t("contact.github.sub"),
    href: "https://github.com/leon4rdodev",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
    color: "#1a2236",
    colorBg: "#f1f5f9",
  },
];
---

<section class="contact-outer sec" id="contact">
  <div class="container">
    <!-- Header -->
    <div class="contact-head animate-on-scroll">
      <h2 class="sec-title" style="font-size:clamp(2.5rem,6vw,4.5rem)">
        {t("contact.head.line1")}
        {t("contact.head.ghost") && <span class="ghost"> {t("contact.head.ghost")}</span>}
        {" "}{t("contact.head.line3")}
      </h2>
      <p class="sec-sub">{t("contact.note")}</p>
    </div>

    <!-- Link cards -->
    <div class="c-cards animate-on-scroll">
      {
        links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="ccard"
            style={`--c:${link.color};--cbg:${link.colorBg}`}
          >
            <div class="cc-icon-wrap" set:html={link.icon} />
            <div class="cc-text">
              <p class="cc-name">{link.name}</p>
              <p class="cc-sub">{link.sub}</p>
            </div>
            <span class="cc-arr">↗</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-outer {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .contact-head { margin-bottom: 3rem; }

  /* Ghost style on light bg */
  .ghost {
    color: transparent;
    -webkit-text-stroke: 2px var(--blue-200);
  }

  /* Cards row */
  .c-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .ccard {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding: 2.25rem 1.5rem;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: var(--fg);
    text-align: center;
    position: relative;
    transition:
      transform 0.25s,
      box-shadow 0.25s,
      border-color 0.22s,
      background 0.22s;
    overflow: hidden;
  }

  .ccard::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--cbg, var(--bg));
    opacity: 0;
    transition: opacity 0.25s;
  }

  .ccard:hover::before { opacity: 1; }

  .ccard:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(37,99,235,0.12);
    border-color: var(--c, var(--accent));
  }

  .cc-icon-wrap {
    width: 56px; height: 56px;
    background: var(--cbg, var(--blue-50));
    border: 1.5px solid var(--border);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c, var(--accent));
    transition: background 0.2s, border-color 0.2s;
    position: relative;
    z-index: 1;
  }

  .cc-icon-wrap :global(svg) { width: 22px; height: 22px; }

  .ccard:hover .cc-icon-wrap {
    background: var(--c, var(--accent));
    border-color: transparent;
    color: #fff;
  }

  .cc-text { position: relative; z-index: 1; }

  .cc-name {
    font-family: var(--display);
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    color: var(--fg);
    margin-bottom: 0.3rem;
    transition: color 0.2s;
  }

  .ccard:hover .cc-name { color: var(--c, var(--accent)); }

  .cc-sub {
    font-size: 0.72rem;
    color: var(--fg-3);
    line-height: 1.5;
  }

  .cc-arr {
    font-size: 0.9rem;
    color: var(--fg-3);
    transition: color 0.2s, transform 0.2s;
    position: relative;
    z-index: 1;
  }

  .ccard:hover .cc-arr {
    color: var(--c, var(--accent));
    transform: translate(3px, -3px);
  }

  /* Responsive */
  @media (max-width: 680px) {
    .c-cards { grid-template-columns: 1fr; max-width: 400px; }
    .ccard { flex-direction: row; text-align: left; padding: 1.4rem 1.5rem; }
    .cc-arr { margin-left: auto; }
  }
</style>
