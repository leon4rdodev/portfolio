---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  {
    name: t("contact.whatsapp"),
    sub: t("contact.whatsapp.sub"),
    href: "https://wa.me/18096654820",
  },
  {
    name: t("contact.email"),
    sub: t("contact.email.sub"),
    href: "mailto:leon4rdodev@gmail.com",
  },
  {
    name: t("contact.github"),
    sub: t("contact.github.sub"),
    href: "https://github.com/leon4rdodev",
  },
];
---

<section class="sec contact-sec" id="contact">
  <div>
    <p class="sec-label">{t("contact.label")}</p>
    <h2 class="contact-head animate-on-scroll">
      {t("contact.head.line1")}{
        t("contact.head.ghost") && (
          <span class="ghost"> {t("contact.head.ghost")}</span>
        )
      }<br />{t("contact.head.line3")}
    </h2>
    <p class="contact-note animate-on-scroll">
      {t("contact.note")}
    </p>
  </div>
  <div class="c-links animate-on-scroll">
    {
      links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="clink"
        >
          <div>
            <p class="cl-name">{link.name}</p>
            <p class="cl-sub">{link.sub}</p>
          </div>
          <span class="cl-arr">↗</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .contact-sec {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-head {
    font-family: var(--display);
    font-size: clamp(3.5rem, 7vw, 7rem);
    line-height: 0.88;
    letter-spacing: 0.02em;
  }

  .contact-note {
    margin-top: 2rem;
    font-size: 0.82rem;
    line-height: 1.85;
    color: rgba(240, 236, 227, 0.48);
    max-width: 340px;
  }

  .c-links {
    display: flex;
    flex-direction: column;
  }

  .clink {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.6rem 0;
    border-top: 1px solid var(--dim);
    text-decoration: none;
    color: var(--white);
    transition: padding-right 0.3s;
  }

  .clink:hover {
    padding-right: 0.7rem;
  }
  .clink:hover .cl-name {
    color: var(--accent);
  }

  .cl-name {
    font-family: var(--display);
    font-size: 1.45rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .cl-sub {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  .cl-arr {
    font-size: 0.9rem;
    color: var(--muted);
    transition:
      transform 0.2s,
      color 0.2s;
  }

  .clink:hover .cl-arr {
    color: var(--accent);
    transform: translate(3px, -3px);
  }

  @media (max-width: 1024px) {
    .contact-sec {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 680px) {
    .contact-head {
      font-size: clamp(3rem, 14vw, 5rem);
    }
  }
</style>
