---
import Layout from "../../../layouts/Layout.astro";
import { languages, type Lang } from "../../../i18n/ui";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };

const featuresIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
];

const data = {
  es: {
    title: "APIs y Backend en RD | Facturación DGII, Pasarelas de Pago, Integraciones",
    description: "Desarrollo de APIs REST y backend en República Dominicana. Integración con facturación electrónica DGII (Ley 32-23), pasarelas de pago Azul y CardNet, APIs con NestJS, PostgreSQL y MongoDB. Desarrollador backend en Santo Domingo.",
    h1: "APIs y Backend para tu Negocio en RD",
    intro: "El backend es el motor invisible de tu negocio digital. Si tu API es lenta, tu sistema de facturación no está integrado con la DGII, o tu pasarela de pago no funciona bien — tu negocio lo resiente. Yo construyo backend robusto que mantiene todo funcionando.",
    problem: {
      h2: "¿Por qué tu negocio en RD necesita un backend bien construido?",
      p: "La facturación electrónica (Ley 32-23) ya es obligatoria en RD. Las pasarelas de pago locales (Azul, CardNet) requieren integraciones específicas. Tu sistema de gestión necesita una API que conecte con tus aplicaciones. Un backend bien diseñado no solo hace todo esto posible — lo hace confiable, rápido y mantenible.",
    },
    features: [
      "APIs REST documentadas con NestJS y TypeScript",
      "Facturación electrónica DGII (e-CF) — integración con proveedores autorizados",
      "Pasarelas de pago: Azul, CardNet, PayPal, Stripe",
      "Bases de datos PostgreSQL y MongoDB — según tu necesidad",
      "Autenticación y autorización (JWT, roles, permisos)",
      "Documentación automática con Swagger/OpenAPI",
      "Testing automatizado — código que no falla",
      "Despliegue en Vercel, AWS o tu propio servidor con Docker",
    ],
    types: {
      h2: "Servicios de backend que ofrezco",
      items: [
        { t: "API REST desde cero", d: "API completa con autenticación, base de datos, documentación y despliegue. Ideal para startups, aplicaciones web y sistemas internos.", p: "Desde US$1,500" },
        { t: "Integración facturación DGII", d: "Conexión de tu sistema con facturación electrónica (e-CF). Cumplimiento con Ley 32-23. Facturación automatizada desde tu POS o sistema de gestión.", p: "Desde US$800" },
        { t: "Integración pasarela de pago", d: "Azul, CardNet o PayPal conectados a tu web o sistema. Pagos recurrentes, facturación automática, sincronización con inventario.", p: "Desde US$600" },
        { t: "API para app móvil", d: "Backend completo para tu aplicación móvil (React Native). Con autenticación, notificaciones push, almacenamiento en la nube.", p: "Desde US$2,000" },
        { t: "Integración con terceros", d: "Conecto tu sistema con APIs externas: WhatsApp Business, redes sociales, servicios financieros, logística, lo que necesites.", p: "Desde US$500" },
      ],
    },
    process: {
      h2: "Cómo desarrollo APIs",
      steps: [
        { n: "01", t: "Definición", d: "Definimos los endpoints, la estructura de datos y las integraciones necesarias. Te presento un documento claro antes de empezar." },
        { n: "02", t: "Arquitectura", d: "Diseño la base de datos, la estructura del API y las reglas de negocio. Todo documentado." },
        { n: "03", t: "Desarrollo", d: "Construyo la API con NestJS, TypeScript y las mejores prácticas. Código limpio y testeable." },
        { n: "04", t: "Documentación", d: "Genero documentación automática con Swagger para que cualquier desarrollador entienda la API." },
        { n: "05", t: "Pruebas", d: "Pruebas de integración, carga y seguridad. La API funciona bajo presión." },
        { n: "06", t: "Despliegue", d: "Pongo la API en producción con monitoreo, logs y escalabilidad automática." },
      ],
    },
    faq: [
      { q: "¿Cuánto cuesta desarrollar una API?", a: "Desde US$1,500 para una API completa. Integraciones específicas desde US$500. Presupuesto detallado antes de empezar." },
      { q: "¿Integras facturación electrónica DGII?", a: "Sí. Conecto tu sistema con los proveedores de e-CF autorizados por la DGII. Facturación electrónica automatizada, envío de comprobantes y cumplimiento fiscal." },
      { q: "¿Qué pasarelas de pago integras?", a: "Azul, CardNet, PayPal y Stripe. Cualquier combinación que necesite tu negocio en RD." },
      { q: "¿La API va a ser rápida?", a: "Sí. Uso NestJS con TypeScript, que es uno de los frameworks más rápidos para Node.js. Además optimizo consultas de base de datos y uso caching cuando es necesario." },
      { q: "¿Me entregas documentación?", a: "Sí. Incluyo documentación automática con Swagger/OpenAPI y documentación escrita para desarrolladores." },
      { q: "¿Y si necesito cambios después?", a: "Ofrezco soporte continuo. El código está estructurado y documentado para que sea fácil de mantener y extender." },
    ],
    cta: "¿Necesitas una API, integración con DGII o una pasarela de pago? Escríbeme por WhatsApp y conversemos.",
    keywords: "APIs RD, backend República Dominicana, facturación electrónica DGII, integración Azul CardNet, desarrollador backend Santo Domingo, API NestJS RD, e-CF RD",
  },
  en: {
    title: "APIs & Backend Development | DGII Integration, Payment Gateways",
    description: "Backend development and API integration for DR businesses. NestJS, PostgreSQL, MongoDB. DGII electronic billing, Azul and CardNet payment gateways.",
    h1: "APIs & Backend Development",
    intro: "The backend is the invisible engine of your digital business. If your API is slow or billing isn't integrated — your business suffers.",
    problem: { h2: "Why your business needs solid backend", p: "DGII electronic billing is mandatory in DR. Local payment gateways need specific integration. A well-built backend makes it all reliable, fast, and maintainable." },
    features: [
      "Documented REST APIs with NestJS and TypeScript",
      "DGII electronic billing (e-CF) integration",
      "Payment gateways: Azul, CardNet, PayPal, Stripe",
      "PostgreSQL and MongoDB databases",
      "JWT authentication, roles, permissions",
      "Swagger/OpenAPI documentation",
      "Automated testing",
      "Docker deployment on Vercel, AWS, or your server",
    ],
    types: {
      h2: "Backend services I offer",
      items: [
        { t: "REST API from scratch", d: "Complete API with auth, database, documentation, deployment.", p: "From $1,500" },
        { t: "DGII billing integration", d: "Connect your system with e-CF providers. Law 32-23 compliance.", p: "From $800" },
        { t: "Payment gateway integration", d: "Azul, CardNet, or PayPal connected to your site or system.", p: "From $600" },
        { t: "Mobile app API", d: "Full backend for React Native apps. Auth, push notifications, cloud storage.", p: "From $2,000" },
      ],
    },
    process: {
      h2: "How I build APIs",
      steps: [
        { n: "01", t: "Definition", d: "Define endpoints, data structure, and integrations needed." },
        { n: "02", t: "Architecture", d: "Design database and API structure. Documented before coding." },
        { n: "03", t: "Development", d: "Build with NestJS, TypeScript, best practices." },
        { n: "04", t: "Documentation", d: "Auto-generated Swagger docs." },
        { n: "05", t: "Testing", d: "Integration, load, and security testing." },
        { n: "06", t: "Deployment", d: "Production deployment with monitoring and auto-scaling." },
      ],
    },
    faq: [
      { q: "How much does an API cost?", a: "From $1,500 for a complete API. Specific integrations from $500." },
      { q: "Do you integrate DGII billing?", a: "Yes. I connect your system with authorized e-CF providers." },
      { q: "Which payment gateways?", a: "Azul, CardNet, PayPal, Stripe. Any combination you need." },
      { q: "Do you provide documentation?", a: "Yes. Swagger/OpenAPI docs plus written developer documentation." },
    ],
    cta: "Need an API or integration? Let's talk.",
    keywords: "API development DR, backend Dominican Republic, payment gateway integration",
  },
}[lang];
---

<Layout title={data.title} description={data.description} lang={lang}>
  <main>
    <section class="svc-hero">
      <div class="container svc-hero-inner">
        <span class="hero-label">{lang === "es" ? "SERVICIO" : "SERVICE"}</span>
        <h1>{data.h1}</h1>
        <p class="hero-intro">{data.intro}</p>
        <a href={`/${lang}/#contact`} class="btn-primary">{lang === "es" ? "Solicitar presupuesto →" : "Get a quote →"}</a>
      </div>
    </section>

    <section class="sec prob-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code p-1"><span class="fn">const</span> <span class="vn">api</span> = <span class="fn">build</span>()</div>
        <div class="glass-code p-2"><span class="st">"reliable"</span>: true</div>
      </div>
      <div class="container prob-inner">
        <span class="sec-label">{lang === "es" ? "EL PROBLEMA" : "THE PROBLEM"}</span>
        <h2 class="sec-title">{data.problem.h2}</h2>
        <blockquote class="prob-quote">{data.problem.p}</blockquote>
      </div>
    </section>

    <section class="sec svc-alt feat-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code f-1">✓ <span class="vn">tested</span></div>
        <div class="glass-code f-2"><span class="fn">deploy</span> --prod</div>
        <div class="glass-code f-3"><span class="st">"docs"</span>: ready</div>
      </div>
      <div class="container">
        <span class="sec-label">{lang === "es" ? "CARACTERÍSTICAS" : "FEATURES"}</span>
        <h2 class="sec-title">{lang === "es" ? "¿Qué incluye?" : "What's included"}</h2>
        <div class="feat-grid">
          {data.features.map((f, i) => (
            <div class="feat-card">
              <div class="feat-icon" set:html={featuresIcons[i]} />
              <p>{f}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec type-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code t-1"><span class="kw">npm run</span> build</div>
        <div class="glass-code t-2"><span class="vn">v1.0.0</span> released</div>
      </div>
      <div class="container">
        <span class="sec-label">{lang === "es" ? "SOLUCIONES" : "SOLUTIONS"}</span>
        <h2 class="sec-title">{data.types.h2}</h2>
        <p class="sec-sub">{lang === "es" ? "Soluciones de backend para tu negocio en RD" : "Backend solutions for your DR business"}</p>
        <div class="type-grid type-grid-5">
          {data.types.items.map((item, i) => (
            <div class="type-card">
              <div class="type-n">{String(i + 1).padStart(2, "0")}</div>
              <h3>{item.t}</h3>
              <p>{item.d}</p>
              <div class="type-footer">
                <span class="type-price">{item.p}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec svc-alt process-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code pr-1"><span class="fn">sprint</span> 1/6</div>
        <div class="glass-code pr-2"><span class="fn">ship</span> it</div>
      </div>
      <div class="container">
        <span class="sec-label">{lang === "es" ? "PROCESO" : "PROCESS"}</span>
        <h2 class="sec-title">{data.process.h2}</h2>
        <div class="process-timeline">
          <div class="timeline-line"></div>
          {data.process.steps.map((s) => (
            <div class="timeline-item">
              <div class="timeline-n">{s.n}</div>
              <div class="timeline-content">
                <h3>{s.t}</h3>
                <p>{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sec faq-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code q-1">? <span class="vn">answer</span></div>
        <div class="glass-code q-2"><span class="fn">help</span>()</div>
      </div>
      <div class="container faq-narrow">
        <span class="sec-label">{lang === "es" ? "FAQ" : "FAQ"}</span>
        <h2 class="sec-title">{lang === "es" ? "Preguntas frecuentes" : "Frequently Asked Questions"}</h2>
        <div class="faq-list">
          {data.faq.map((faq) => (
            <details class="faq-item" name="svc-faq">
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="section-decor" aria-hidden="true">
        <div class="glass-code c-1"><span class="kw">const</span> <span class="vn">project</span> = <span class="kw">await</span> <span class="fn">start</span>()</div>
        <div class="glass-code c-2"><span class="fn">ready</span> = <span class="kw">true</span></div>
      </div>
      <div class="container" style="text-align:center;position:relative;z-index:1">
        <p class="cta-text">{data.cta}</p>
        <a href={`/${lang}/#contact`} class="btn-primary btn-lg">{lang === "es" ? "Hablemos por WhatsApp →" : "Let's talk →"}</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  body { background: var(--surface); }
  .svc-hero { background: var(--surface); padding: 9rem 2rem 5rem; text-align: center; position: relative; overflow: hidden; }
  .svc-hero-inner { position: relative; z-index: 1; }
  .hero-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; display: block; }
  .svc-hero h1 { font-family: var(--display); font-size: clamp(2.4rem, 5vw, 3.8rem); letter-spacing: 0.04em; line-height: 1; color: var(--fg); margin-bottom: 1rem; }
  .hero-intro { font-size: 1.05rem; line-height: 1.7; color: var(--fg-2); max-width: 600px; margin: 0 auto 2rem; }

  .sec { padding: 6rem 2rem; }
  .svc-alt { background: var(--surface); }

  .prob-section { position: relative; overflow: hidden; }
  .prob-inner { max-width: 720px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .prob-quote { font-size: 1.05rem; line-height: 1.85; color: var(--fg-2); text-align: left; margin-top: 1.5rem; }

  .feat-section { position: relative; overflow: hidden; }
  .feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2.5rem; position: relative; z-index: 1; }
  .feat-card { padding: 1.75rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s; display: flex; flex-direction: column; align-items: flex-start; gap: 0.75rem; }
  .feat-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(37,99,235,0.1); border-color: var(--blue-200); }
  .feat-icon { width: 44px; height: 44px; background: var(--accent-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--accent); flex-shrink: 0; transition: background 0.3s, color 0.3s; }
  .feat-card:hover .feat-icon { background: var(--accent); color: #fff; }
  .feat-icon :global(svg) { width: 20px; height: 20px; }
  .feat-card p { font-size: 0.88rem; line-height: 1.65; color: var(--fg-2); margin: 0; }

  .type-section { position: relative; overflow: hidden; }
  .type-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 2.5rem; position: relative; z-index: 1; }
  .type-grid-5 { grid-template-columns: repeat(3, 1fr); }
  .type-card { padding: 2rem; border: 1px solid var(--border); border-radius: var(--radius-xl); background: var(--surface); transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s; display: flex; flex-direction: column; }
  .type-card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(37,99,235,0.1); border-color: var(--blue-200); }
  .type-n { font-family: var(--display); font-size: 1.8rem; letter-spacing: 0.08em; color: var(--accent); line-height: 1; margin-bottom: 0.75rem; opacity: 0.5; }
  .type-card h3 { font-family: var(--display); font-size: 1.25rem; letter-spacing: 0.06em; color: var(--fg); margin-bottom: 0.5rem; }
  .type-card p { font-size: 0.85rem; line-height: 1.7; color: var(--fg-3); margin: 0 0 1.25rem; flex: 1; }
  .type-footer { margin-top: auto; }
  .type-price { display: inline-block; font-size: 0.8rem; font-weight: 700; color: var(--accent); background: var(--blue-50); padding: 0.35rem 0.85rem; border-radius: 50px; transition: background 0.3s, color 0.3s; }
  .type-card:hover .type-price { background: var(--accent); color: #fff; }

  .process-section { position: relative; overflow: hidden; }
  .process-timeline { max-width: 640px; margin: 2.5rem auto 0; position: relative; z-index: 1; }
  .timeline-line { position: absolute; left: 24px; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--blue-200), var(--blue-500)); }
  .timeline-item { display: flex; gap: 1.25rem; margin-bottom: 1.5rem; position: relative; }
  .timeline-item:last-child { margin-bottom: 0; }
  .timeline-n { width: 50px; height: 50px; border-radius: 50%; background: var(--surface); border: 2px solid var(--accent); display: flex; align-items: center; justify-content: center; font-family: var(--display); font-size: 1rem; color: var(--accent); flex-shrink: 0; position: relative; z-index: 1; transition: background 0.3s, color 0.3s; }
  .timeline-item:hover .timeline-n { background: var(--accent); color: #fff; }
  .timeline-content { padding: 0.5rem 0; }
  .timeline-content h3 { font-size: 1rem; font-weight: 700; color: var(--fg); margin-bottom: 0.25rem; }
  .timeline-content p { font-size: 0.85rem; line-height: 1.6; color: var(--fg-3); margin: 0; }

  .faq-section { position: relative; overflow: hidden; }
  .faq-narrow { max-width: 720px; margin: 0 auto; position: relative; z-index: 1; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2.5rem; }
  .faq-item { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); transition: border-color 0.2s, box-shadow 0.2s; }
  .faq-item[open] { border-color: var(--accent); box-shadow: 0 4px 16px rgba(37,99,235,0.06); }
  .faq-item summary { padding: 1.15rem 1.5rem; font-weight: 600; font-size: 0.92rem; color: var(--fg); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; font-size: 1.2rem; color: var(--accent); transition: transform 0.25s; line-height: 1; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { padding: 0 1.5rem 1.25rem; font-size: 0.88rem; line-height: 1.75; color: var(--fg-2); margin: 0; }

  .cta-section { padding: 6rem 2rem; background: var(--surface); position: relative; overflow: hidden; }
  .cta-text { font-size: 1.2rem; line-height: 1.7; color: var(--fg-2); max-width: 600px; margin: 0 auto 2rem; }
  .btn-lg { padding: 1rem 2.5rem; font-size: 1rem; }

  .h-1 { top: 6%; left: 4%; } .h-2 { top: 12%; right: 6%; } .h-4 { bottom: 22%; right: 4%; transform: rotate(-3deg); } .h-5 { top: 65%; left: 3%; opacity: 0.6; } .h-8 { bottom: 8%; left: 6%; opacity: 0.5; }
  .p-1 { top: 18%; right: 5%; } .p-2 { bottom: 15%; left: 4%; opacity: 0.5; }
  .f-1 { top: 10%; left: 5%; } .f-2 { top: 50%; right: 4%; transform: rotate(5deg); opacity: 0.5; } .f-3 { bottom: 8%; left: 8%; opacity: 0.4; }
  .t-1 { bottom: 12%; right: 4%; } .t-2 { top: 8%; left: 4%; opacity: 0.5; }
  .pr-1 { top: 10%; right: 5%; } .pr-2 { bottom: 10%; left: 5%; opacity: 0.5; transform: rotate(-5deg); }
  .q-1 { top: 12%; right: 4%; } .q-2 { bottom: 15%; left: 4%; opacity: 0.5; }
  .c-1 { top: 12%; left: 5%; } .c-2 { bottom: 12%; right: 5%; opacity: 0.5; }

  @media (max-width: 1024px) { .glass-code { display: none; } }
  @media (max-width: 768px) {
